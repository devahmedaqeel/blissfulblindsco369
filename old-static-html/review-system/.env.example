# Copy this file to .env and fill in real values before deploying.
# Never commit the real .env file.

# Server
PORT=4000
NODE_ENV=production

# Comma-separated list of origins allowed to call this API from a browser.
# Must include the real domain(s) the site is served from.
CORS_ORIGINS=https://blissfulblindsco369.com,http://localhost:8080

# Admin authentication
# JWT_SECRET must be a long random string — e.g. generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=8h

# Cloudflare Turnstile (https://dash.cloudflare.com/?to=/:account/turnstile)
# Leave TURNSTILE_SECRET_KEY empty during local development to skip
# verification — the server will log a loud warning when it does. Do NOT
# deploy to production without a real secret key configured.
TURNSTILE_SECRET_KEY=

# Rate limiting (requests per window, per IP)
REVIEW_SUBMIT_RATE_LIMIT=5
REVIEW_SUBMIT_RATE_WINDOW_MINUTES=15
ADMIN_LOGIN_RATE_LIMIT=10
ADMIN_LOGIN_RATE_WINDOW_MINUTES=15
NOTIFY_SUBMIT_RATE_LIMIT=5
NOTIFY_SUBMIT_RATE_WINDOW_MINUTES=15

# ---------------------------------------------------------------------
# Email (Nodemailer over Gmail SMTP)
# ---------------------------------------------------------------------
# EMAIL_USER must be a real Gmail address, and EMAIL_PASS must be a Gmail
# *App Password* (16 characters, no spaces) — NOT the normal account
# password. Gmail requires 2-Step Verification to be turned on before it
# will let you generate an App Password:
#   1. https://myaccount.google.com/security -> turn on 2-Step Verification
#   2. https://myaccount.google.com/apppasswords -> generate one for "Mail"
#   3. Paste the 16-character code below (EMAIL_PASS)
EMAIL_USER=blissfulblindsco369@gmail.com
EMAIL_PASS=

# Where admin notification emails are sent. Defaults to EMAIL_USER if unset.
EMAIL_ADMIN_TO=blissfulblindsco369@gmail.com

# Display name customers see in their inbox ("From: Blissful Blinds Co <...>")
EMAIL_FROM_NAME=Blissful Blinds Co

# If EMAIL_PASS is left blank, the server logs a loud warning and uses
# Nodemailer's Ethereal test SMTP service instead (a real, free, fake
# inbox meant exactly for this) so the whole pipeline still works end to
# end during development — nothing is ever silently dropped. Do NOT
# deploy to production without EMAIL_PASS set to a real Gmail App
# Password, or customers/admin will never receive real email.
