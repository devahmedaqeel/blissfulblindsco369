# Copy this file to .env and fill in real values before deploying.
# Never commit the real .env file.

# Server
PORT=4000
NODE_ENV=production

# Comma-separated list of origins allowed to call this API from a browser.
# Must include the real domain(s) the site is served from.
CORS_ORIGINS=https://blissfulblindsltd.co.uk,http://localhost:8080

# Admin authentication
# JWT_SECRET must be a long random string — e.g. generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=8h

# Cloudflare Turnstile (https://dash.cloudflare.com/?to=/:account/turnstile)
# Leave TURNSTILE_SECRET_KEY empty during local development to skip
# verification — the server will log a loud warning when it does. Do NOT
# deploy to production without a real secret key configured.
TURNSTILE_SECRET_KEY=

# Rate limiting (requests per window, per IP)
REVIEW_SUBMIT_RATE_LIMIT=5
REVIEW_SUBMIT_RATE_WINDOW_MINUTES=15
ADMIN_LOGIN_RATE_LIMIT=10
ADMIN_LOGIN_RATE_WINDOW_MINUTES=15
NOTIFY_SUBMIT_RATE_LIMIT=5
NOTIFY_SUBMIT_RATE_WINDOW_MINUTES=15

# ---------------------------------------------------------------------
# Email (Nodemailer over Hostinger SMTP)
# ---------------------------------------------------------------------
# SMTP_USER must be a real Hostinger mailbox (Titan Mail) address, and
# SMTP_PASS must be that mailbox's real password. Create/manage the
# mailbox at hpanel.hostinger.com -> Emails.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@blissfulblindsltd.co.uk
SMTP_PASS=

# From header customers/admin see ("From: Blissful Blinds Ltd <info@...>").
MAIL_FROM=Blissful Blinds Ltd <info@blissfulblindsltd.co.uk>

# Where admin notification emails are sent. Defaults to SMTP_USER if unset.
MAIL_TO=info@blissfulblindsltd.co.uk

# If SMTP_PASS is left blank, the server logs a loud warning and uses
# Nodemailer's Ethereal test SMTP service instead (a real, free, fake
# inbox meant exactly for this) so the whole pipeline still works end to
# end during development — nothing is ever silently dropped. Production
# refuses to start at all without SMTP_USER/SMTP_PASS set (see config.js).
