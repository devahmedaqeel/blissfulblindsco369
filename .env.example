# Copy to .env.local for local `vercel dev`, and set the same keys in the
# Vercel project's Environment Variables (Project Settings -> Environment
# Variables) for Preview/Production. Never commit the real values.
#
# Used by api/notify.js (booking form + AI chatbot lead form) via
# api/_lib/mailer.js.

# ---------------------------------------------------------------------
# Email (Nodemailer over Hostinger SMTP)
# ---------------------------------------------------------------------
# Create/confirm the mailbox first: hpanel.hostinger.com -> Emails ->
# info@blissfulblindsltd.co.uk. SMTP_PASS is that mailbox's real password
# (not your Hostinger account password).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@blissfulblindsltd.co.uk
SMTP_PASS=

# From header recipients see in their inbox.
MAIL_FROM=Blissful Blinds Ltd <info@blissfulblindsltd.co.uk>

# Where admin notification emails (every booking/chatbot lead) are sent.
MAIL_TO=info@blissfulblindsltd.co.uk

# If SMTP_USER/SMTP_PASS are left blank, local `vercel dev` falls back to
# Nodemailer's Ethereal test SMTP (logs a preview URL instead of sending
# real mail) so the flow is still testable end to end. In production
# (VERCEL_ENV=production, set automatically by Vercel) this fallback is
# disabled — sendMail will fail loudly instead of silently doing nothing.

# ---------------------------------------------------------------------
# Order Management & Notification System (New Upgrades)
# ---------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/blissful-blinds
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USER=info@blissfulblindsltd.co.uk
EMAIL_PASS=your-hostinger-mailbox-password
OWNER_EMAIL=owner@email.com

# WhatsApp settings (Meta Cloud API)
OWNER_WHATSAPP_NUMBER=+447341645339
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=your-meta-phone-number-id
META_VERIFY_TOKEN=your-verify-token-for-webhooks

# JSON Web Token Secret (Dashboard Auth)
JWT_SECRET=generate-a-long-random-string-at-least-32-characters
JWT_EXPIRES_IN=8h
